# Watchlist source images — faces are sensitive PII, never commit.
watchlist/*.jpg
watchlist/*.jpeg
watchlist/*.png
watchlist/*.JPG
watchlist/*.JPEG
watchlist/*.PNG

# Model weights downloaded at runtime
*.pt
*.onnx
*.mlpackage
*.mlmodel
yolo*.pt

# Editor
.vscode/
.idea/
*.swp

# Playwright MCP scratch
.playwright-mcp/

# Input footage — exceeds GitHub's 100MB per-file limit and is not part of
# the source. Cameras / folders themselves are tracked via .gitkeep so the
# discovery code finds them after a fresh clone; drop your own .mp4/.mov
# files in to use the pipeline locally.
videos/**/*.mp4
videos/**/*.mov
videos/**/*.MP4
videos/**/*.MOV
videos/**/*.avi
videos/**/*.mkv
